# Gemini API Configuration (for query translation)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=YOUR_API_KEY

# OpenAlex API Configuration
OPENALEX_API_KEY=YOUR_API_KEY

# OpenAlex Configuration (recommended for polite pool access)
# Use your email to get faster rate limits
OPENALEX_EMAIL=your_email@example.com

# OA Downloader Configuration
# Default email for Unpaywall API (required for downloads)
UNPAYWALL_EMAIL=your_email@example.com
